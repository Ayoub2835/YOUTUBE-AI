# Copy this file to .env and fill in the providers you plan to use.
# Every provider has a working offline/free fallback, so StoryGen runs
# out of the box even with this file left mostly empty.

# --- General ---
OUTPUT_DIR=output
ASSETS_DIR=assets
LOG_DIR=logs
LOG_LEVEL=INFO

# --- LLM provider for story / script / metadata generation ---
# Options: openai | anthropic | mock
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_TEXT_MODEL=claude-sonnet-5

# --- Text-to-speech ---
# Options: elevenlabs | openai | gtts (free, no key) | pyttsx3 (fully offline)
TTS_PROVIDER=gtts
ELEVENLABS_API_KEY=
# Víctor - Persuasive Storyteller: natural Mexican-Spanish male voice
ELEVENLABS_VOICE_ID=tSdO3lUIODN7SK6eWVhu
OPENAI_TTS_VOICE=alloy
TTS_LANGUAGE=en

# --- Scene image generation ---
# Options: openai | stability | placeholder (offline, no key)
IMAGE_PROVIDER=placeholder
STABILITY_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1792

# --- Subtitles ---
# Options: even (no dependency) | whisper (requires `pip install faster-whisper`)
SUBTITLE_MODE=even
WHISPER_MODEL_SIZE=base

# --- Video assembly ---
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
VIDEO_FPS=30
TRANSITION_DURATION=0.6
MUSIC_VOLUME_DB=-22
SCENE_MIN_DURATION=3.0

# --- Export targets ---
EXPORT_PLATFORMS=youtube,tiktok,snapchat

# --- Publishing (official APIs, optional) ---
AUTO_PUBLISH=false

# YouTube Data API v3 (OAuth "installed app" flow)
YOUTUBE_CLIENT_SECRETS_FILE=
YOUTUBE_TOKEN_FILE=.secrets/youtube_token.json
YOUTUBE_PRIVACY_STATUS=private

# TikTok Content Posting API
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# Snapchat (no public organic-post API yet -- see storygen/publishing/snapchat_publisher.py)
SNAPCHAT_ACCESS_TOKEN=
